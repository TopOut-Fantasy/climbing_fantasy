<div class="flex flex-col items-center justify-center min-h-screen px-4 py-12">
  <div class="text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-2">
      <%= image_tag("top_out_logo.png", alt: "TopOut", class: "h-12 w-12") %>
      <h1 class="text-3xl font-bold text-white">TopOut</h1>
    </div>
  </div>

  <div class="w-full max-w-md bg-gray-900 rounded-2xl p-8 border border-gray-800">
    <h2 class="text-2xl font-bold text-white mb-1">Forgot Password</h2>
    <p class="text-gray-400 text-sm mb-6">Enter your email and we'll send you reset instructions</p>

    <%= render "users/shared/error_messages", resource: resource %>

    <% if flash[:notice] %>
      <div class="bg-accent/10 border border-accent/30 rounded-lg p-4 mb-6">
        <p class="text-accent text-sm"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <div>
        <label for="user_email" class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "w-full bg-gray-800 border border-gray-700 rounded-lg py-2.5 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent" %>
        </div>
      </div>

      <div>
        <%= f.submit "Send Reset Instructions", class: "w-full bg-accent hover:bg-accent-hover text-gray-900 font-semibold py-2.5 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-center text-gray-400 text-sm mt-6">
      Remember your password?
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-accent hover:text-accent-hover font-semibold" %>
    </p>
  </div>
</div>
