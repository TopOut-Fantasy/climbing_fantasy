<div class="flex flex-col items-center justify-center min-h-screen px-4 py-12">
  <div class="text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-4">
      <%= image_tag("top_out_logo.png", alt: "TopOut", class: "h-12 w-12") %>
      <h1 class="text-3xl font-bold text-white">TopOut</h1>
    </div>
  </div>

  <div class="w-full max-w-lg bg-gray-900 rounded-2xl p-8 border border-gray-800 text-center">
    <h2 class="text-2xl font-bold text-white mb-2">Welcome back, <%= current_user.display_name %>!</h2>
    <p class="text-gray-400 mb-8">Your climbing fantasy dashboard is coming soon.</p>

    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-gray-800 rounded-lg p-4">
        <p class="text-2xl font-bold text-accent">0</p>
        <p class="text-xs text-gray-400 mt-1">Leagues</p>
      </div>
      <div class="bg-gray-800 rounded-lg p-4">
        <p class="text-2xl font-bold text-accent">0</p>
        <p class="text-xs text-gray-400 mt-1">Athletes</p>
      </div>
      <div class="bg-gray-800 rounded-lg p-4">
        <p class="text-2xl font-bold text-accent">0</p>
        <p class="text-xs text-gray-400 mt-1">Points</p>
      </div>
    </div>

    <div class="flex justify-center gap-4">
      <%= link_to "Edit Account", edit_user_registration_path, class: "text-sm text-accent hover:text-accent-hover" %>
      <span class="text-gray-700">|</span>
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-sm text-gray-400 hover:text-white cursor-pointer" %>
    </div>
  </div>
</div>
