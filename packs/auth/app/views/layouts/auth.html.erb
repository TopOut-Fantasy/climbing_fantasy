<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TopOut — Fantasy Climbing" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="TopOut">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/top_out_favicon.png" type="image/png">
    <link rel="shortcut icon" href="/top_out_favicon.png" type="image/png">
    <link rel="apple-touch-icon" href="/top_out_favicon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 min-h-screen flex items-center justify-center">
    <main class="w-full">
      <%= yield %>
    </main>
  </body>
</html>
